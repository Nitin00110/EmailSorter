# ==========================================
# EMAIL SORTER - ENVIRONMENT VARIABLES SETUP
# ==========================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to exactly '.env'
# 2. Fill in your actual API keys below
# 3. DO NOT commit the real '.env' file to version control!
# ==========================================

# --- 1. GEMINI AI CONFIGURATION ---
# Get your free Gemini API key here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- 2. GOOGLE OAUTH2 CREDENTIALS ---
# Set up OAuth 2.0 Client IDs in the Google Cloud Console: https://console.cloud.google.com/
clientId=your_google_oauth_client_id_here
clientSecret=your_google_oauth_client_secret_here

# --- 3. DATABASE CONFIGURATION ---
# These are the default values for the Dockerized PostgreSQL database.
# You can leave these exactly as they are for local development.
DB_NAME=emailsorter_db
DB_USER=postgres
DB_PASSWORD=local_dev_password_123